{#
  Glass-style date/info pill for the hero. Matches .hero-badge.
  Solid hex colors only (rgba is unsupported in some email clients).
  Usage:
    {% include 'emails/components/hero_badge.html.twig' with {label: 'Reçu le 17/05/2026'} %}
#}
<div style="display:inline-block;background-color:#2a4666;border:1px solid #3a5478;border-radius:50px;padding:6px 14px;font-size:12px;color:#ffffff;font-weight:500;">
<span style="display:inline-block;width:8px;height:8px;background-color:#f4a261;border-radius:50%;margin-right:8px;vertical-align:middle;"></span>{{ label }}
</div>
