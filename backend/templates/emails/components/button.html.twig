{#
  Red CTA button matching the site's .btn-primary.
  Usage:
    {% include 'emails/components/button.html.twig' with {href: 'mailto:foo@bar', label: 'Répondre'} %}
#}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
<tr><td align="center">
<a href="{{ href }}" style="display:inline-block;background-color:#e63946;color:#ffffff;text-decoration:none;font-size:15px;font-weight:600;padding:14px 32px;border-radius:8px;box-shadow:0 8px 24px rgba(230,57,70,0.3);">{{ label }}</a>
</td></tr>
</table>
