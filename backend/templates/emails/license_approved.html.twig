{% extends 'emails/layout.html.twig' %}

{% block title %}Votre licence est validée{% endblock %}

{% block hero_eyebrow %}Adhésion {{ season }}{% endblock %}

{% block hero_title %}
Votre licence<br><span style="color:#f4a261;">est validée !</span>
{% endblock %}

{% block hero_meta %}
{% include 'emails/components/hero_badge.html.twig' with {label: 'Saison ' ~ season} %}
{% endblock %}

{% block body %}

<div style="font-size:16px;line-height:1.7;color:#1a1a2e;">
Bonjour <strong>{{ firstName }}</strong>,<br><br>
Bonne nouvelle&nbsp;: votre demande de licence a été validée par le club. Il ne reste plus qu'à régler votre adhésion en ligne, de façon sécurisée via HelloAsso.
</div>

<div style="margin:24px 0;">
{% embed 'emails/components/card.html.twig' %}
{% block eyebrow %}Montant de la licence{% endblock %}
{% block content %}
<div style="font-size:28px;font-weight:800;color:#1a1a2e;letter-spacing:-0.01em;">{{ amount }}&nbsp;€</div>
{% endblock %}
{% endembed %}
</div>

{% include 'emails/components/button.html.twig' with {href: paymentUrl, label: 'Régler ma licence'} %}

<div style="margin-top:24px;font-size:13px;line-height:1.6;color:#6b7280;">
Si le bouton ne fonctionne pas, copiez ce lien dans votre navigateur&nbsp;:<br>
<a href="{{ paymentUrl }}" style="color:#1e3a5f;word-break:break-all;">{{ paymentUrl }}</a>
</div>

{% endblock %}

{% block footer_note %}
Paiement sécurisé via HelloAsso · <a href="https://clapiersvb.fr" style="color:#f4a261;text-decoration:none;">clapiersvb.fr</a>
{% endblock %}
