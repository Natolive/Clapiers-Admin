{% extends 'emails/layout.html.twig' %}

{% block title %}Votre licence est réglée{% endblock %}

{% block hero_eyebrow %}Paiement confirmé{% endblock %}

{% block hero_title %}
Merci {{ firstName }},<br><span style="color:#f4a261;">c'est réglé !</span>
{% endblock %}

{% block hero_meta %}
{% include 'emails/components/hero_badge.html.twig' with {label: 'Saison ' ~ season} %}
{% endblock %}

{% block body %}

<div style="font-size:16px;line-height:1.7;color:#1a1a2e;">
Nous confirmons la réception de votre paiement. Votre adhésion pour la saison <strong>{{ season }}</strong> est désormais à jour.
</div>

<div style="margin:24px 0;">
{% embed 'emails/components/card.html.twig' %}
{% block eyebrow %}Montant réglé{% endblock %}
{% block content %}
<div style="font-size:28px;font-weight:800;color:#1a1a2e;letter-spacing:-0.01em;">{{ amount }}&nbsp;€</div>
{% endblock %}
{% endembed %}
</div>

<div style="font-size:15px;line-height:1.7;color:#1a1a2e;">
À très vite sur les terrains&nbsp;! 🏐
</div>

{% endblock %}
