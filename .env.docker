# Docker Compose environment variables
# Copy this to .env and adjust as needed

# PostgreSQL
POSTGRES_DB=clapiers_db
POSTGRES_USER=symfony
POSTGRES_PASSWORD=symfony

# Symfony
APP_ENV=dev
APP_SECRET=local_dev_secret_change_me_in_prod

# JWT
JWT_PASSPHRASE=dev_passphrase

# Xdebug (off | debug | profile | coverage)
XDEBUG_MODE=off
