# ============================================================================
# Project-wide environment variables — template
# ----------------------------------------------------------------------------
# Copy this file to `.env` at the project root and fill in real values.
# `.env` is gitignored. Never commit real secrets.
# ============================================================================

# --- PostgreSQL ---
POSTGRES_DB=clapiers_db
POSTGRES_USER=symfony
POSTGRES_PASSWORD=symfony

# --- Symfony (backend) ---
APP_ENV=dev
APP_SECRET=change_me
DEFAULT_URI=http://api.clapiers.local
JWT_PASSPHRASE=change_me
JWT_TOKEN_TTL=3600
CORS_ALLOW_ORIGIN=^https?://(app\.clapiers\.local|localhost)(:[0-9]+)?$
XDEBUG_MODE=off

# --- Mailer (Brevo transactional) ---
# Use brevo+api://YOUR_BREVO_API_KEY@default to send via Brevo.
# Set to null://null to disable email sending entirely.
MAILER_DSN=null://null

# --- Contact form notification addresses ---
CONTACT_RECIPIENT_EMAIL=info@clapiersvb.fr
CONTACT_SENDER_EMAIL=info@clapiersvb.fr

# --- Google reCAPTCHA v2 (checkbox) ---
# Register a site at https://www.google.com/recaptcha/admin/create
# (choose "reCAPTCHA v2 — I'm not a robot Checkbox", add domains
#  clapiersvb.fr and localhost) then paste the keys below.
# Leave both empty to disable captcha verification (dev convenience).
NUXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- HelloAsso (paiement des licences) ---
# Identifiants API depuis l'espace HelloAsso : Mon compte > Intégrations et API.
# Sandbox : https://api.helloasso-sandbox.com — Prod : https://api.helloasso.com
# Les tarifs sont gérés dans un formulaire d'adhésion HelloAsso ; renseigner son
# type (Membership) et son slug pour que l'app lise les tiers via l'API.
HELLOASSO_BASE_URL=https://api.helloasso-sandbox.com
HELLOASSO_CLIENT_ID=
HELLOASSO_CLIENT_SECRET=
HELLOASSO_ORGANIZATION_SLUG=
HELLOASSO_MEMBERSHIP_FORM_TYPE=Membership
HELLOASSO_MEMBERSHIP_FORM_SLUG=
# URL publique du frontend (magic link de paiement + URLs de retour HelloAsso)
APP_FRONTEND_URL=http://app.clapiers.local

# --- Frontend (Nuxt) ---
NUXT_PUBLIC_API_BASE=http://api.clapiers.local/api
